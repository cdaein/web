---
import data from "@data/activities";
import ActivityListItem from "@components/mdx/ActivityListItem.astro";
import type { Activity } from "@data/activities";

type Props = {
  slug: string | string[];
  /** Show separate list per activity type */
  sortByType?: boolean;
  showWorkTitle?: boolean;
  class?: string;
};

// Display order follows this object's key order
const typeLUT = {
  service: "Service",
  exhibition: "Selected Exhibitions",
  screening: "Selected Screenings",
  teaching: "Teaching",
  lecture: "Talks/Lectures",
  event: "Events",
  award: "Selected Awards",
  publication: "Publications",
  featured: "Featured",
  interview: "Interview",
} as const;

const {
  slug,
  sortByType = false,
  showWorkTitle = false,
  class: className,
} = Astro.props;

// support multiple slugs for a single event
const activities = slug
  ? data.filter((act: Activity) => {
      if (!act.slug) return false;
      const actSlugs = Array.isArray(act.slug) ? act.slug : [act.slug];
      const pageSlugs = Array.isArray(slug) ? slug : [slug];
      return actSlugs.some((s) => pageSlugs.includes(s));
    })
  : data;

const sortedActivities = activities.reduce(
  (acc: Record<Activity["type"], Activity[]>, activity) => {
    const { type } = activity;

    acc[type] = acc[type] || [];
    acc[type].push(activity);
    return acc;
  },
  {} as Record<Activity["type"], Activity[]>,
);

// order activity types per typeLUT, skipping any with no entries
const activityTypes = (Object.keys(typeLUT) as (keyof typeof typeLUT)[]).filter(
  (type) => sortedActivities[type]?.length,
);

const mapHeader = (type: keyof typeof typeLUT) => typeLUT[type];
---

<section class:list={["activity-wrapper", className]}>
  {
    sortByType ? (
      activityTypes.map((type) => (
        <>
          <h2 class="m-0 pl-0 text-base">{mapHeader(type)}</h2>
          <ul role="list">
            {sortedActivities[type].map((act) => (
              <ActivityListItem data={act} showWorkTitle={showWorkTitle} />
            ))}
          </ul>
        </>
      ))
    ) : (
      <ul role="list">
        {activities.map((act) => (
          <ActivityListItem data={act} showWorkTitle={showWorkTitle} />
        ))}
      </ul>
    )
  }
</section>
